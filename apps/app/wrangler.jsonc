{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stubramp-app",
  "compatibility_date": "2025-09-02",
  // Pure static SPA: serve the Vite build output as assets, falling back to
  // index.html so client-side routes resolve. No Worker script / SSR entry.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
