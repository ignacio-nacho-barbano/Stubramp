# Local Postgres (docker-compose.yml). Loaded instead of .env.local when
# USE_LOCAL_DB=1 is set (see src/env.ts and prisma.config.ts).
# These are throwaway local dev credentials — safe to commit, not secrets.
#
# No PgBouncer locally, so pooled and direct point at the same instance.
# No TLS on local Postgres, so sslmode=disable.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stubramp?sslmode=disable"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/stubramp?sslmode=disable"
