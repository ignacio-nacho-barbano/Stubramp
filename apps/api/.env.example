## Secrets
JWT_SECRET=
PASSWORD_PEPPER=

# DB
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Local DB alternative (optional, no Neon needed) ---
# Run a local Postgres in Docker instead of Neon:
#   pnpm db:up && pnpm db:migrate:docker && pnpm dev:docker
# Setting USE_LOCAL_DB=1 loads .env.docker (committed) instead of .env.local.
# USE_LOCAL_DB=1

# Server (Fly.io must bind 0.0.0.0).
HOST="0.0.0.0"
PORT="3001"

#Shared monorepo vars
API_URL=http://localhost:3001
APP_URL=http://localhost:3000
ENV=local

# Allowed browser origins (comma-separated). One domain in prod; the two local
# dev servers locally. Credentials mode forbids `*`, so list each origin.
CORS_WHITELIST=http://localhost:3000,http://localhost:3001
