{
  "name": "Stubramp",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter @stubramp/app --filter @stubramp/api",
    "dev:local": "pnpm --filter @stubramp/api db:up && USE_LOCAL_DB=1 turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "deploy:api": "fly deploy . -c apps/api/fly.toml --dockerfile apps/api/Dockerfile --ignorefile apps/api/Dockerfile.dockerignore --ha=false",
    "db:migrate": "pnpm --filter @stubramp/api db:migrate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  }
}
